---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PaperEntry from '../../components/PaperEntry.astro';
import { t, localeStaticPaths, type Locale } from '../../i18n';
import { papersByYear } from '../../lib/papers';
import { labOrganization, scholarlyArticle } from '../../lib/jsonld';
import tagcolors from '../../data/tagcolors.json';

export function getStaticPaths() {
  return localeStaticPaths();
}
const locale = Astro.params.locale as Locale;

const papers = await getCollection('papers');
const byYear = papersByYear(papers);
const usedTags = [...new Set(papers.filter((p) => !p.data.draft).flatMap((p) => p.data.tags))].sort();
const colors = tagcolors as Record<string, string>;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [labOrganization, ...papers.filter((p) => !p.data.draft).map((p) => scholarlyArticle(p.data))],
};
---

<Base locale={locale} title={t(locale, 'papers.title')} jsonLd={jsonLd}>
  <h1>{t(locale, 'papers.title')}</h1>

  <details id="tag-filter">
    <summary>
      {t(locale, 'papers.filterByTag')}
      <span id="active-tags" class="active-tags"></span>
    </summary>
    <div class="tag-list">
      {
        usedTags.map((tag) => (
          <label class="tag-chip" style={`background:${colors[tag] ?? '#eee'}`}>
            <input type="checkbox" value={tag} />
            {tag}
          </label>
        ))
      }
    </div>
    <button type="button" id="clear-filter" hidden>{t(locale, 'papers.clearFilter')}</button>
  </details>

  {
    byYear.map(({ year, papers: yearPapers }) => (
      <section data-year-section>
        <h2>{year}</h2>
        <ul class="paper-list">
          {yearPapers.map((paper) => (
            <PaperEntry paper={paper} locale={locale} />
          ))}
        </ul>
      </section>
    ))
  }

  <p><a href="/papers.csl.json">{t(locale, 'papers.cslExport')}</a></p>

  <script>
    // Progressive enhancement: tag filtering. Without JS everything is visible.
    const boxes = [...document.querySelectorAll<HTMLInputElement>('#tag-filter input')];
    const clear = document.getElementById('clear-filter')!;
    const activeLabel = document.getElementById('active-tags')!;
    function apply() {
      const active = boxes.filter((b) => b.checked).map((b) => b.value);
      clear.hidden = active.length === 0;
      activeLabel.textContent = active.length ? `— ${active.join(', ')}` : '';
      for (const li of document.querySelectorAll<HTMLElement>('li[data-tags]')) {
        const tags = (li.dataset.tags ?? '').split('|');
        li.hidden = active.length > 0 && !active.some((t) => tags.includes(t));
      }
      for (const section of document.querySelectorAll<HTMLElement>('[data-year-section]')) {
        section.hidden = !section.querySelector('li:not([hidden])');
      }
    }
    boxes.forEach((b) => b.addEventListener('change', apply));
    clear.addEventListener('click', () => {
      boxes.forEach((b) => (b.checked = false));
      apply();
    });
  </script>
</Base>

<style>
  #tag-filter {
    border: 2px solid var(--c-black);
    margin-block: var(--grid);
  }
  #tag-filter summary {
    font-weight: 700;
    padding: 0.75em var(--grid);
  }
  #tag-filter summary:hover {
    background: var(--c-light-blue);
  }
  .active-tags {
    font-weight: 400;
    font-size: var(--text-s);
    color: var(--c-dark-grey);
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    padding: 0 var(--grid) var(--grid);
  }
  #clear-filter {
    margin: 0 var(--grid) var(--grid);
  }
  #tag-filter label {
    cursor: pointer;
  }
  #tag-filter label:has(input:checked) {
    outline: 3px solid var(--c-black);
  }
  #tag-filter input {
    margin-right: 0.3em;
  }
  #clear-filter {
    border: 2px solid var(--c-black);
    background: var(--c-white);
    font: inherit;
    font-size: var(--text-s);
    cursor: pointer;
    padding: 0.1em 0.6em;
  }
  #clear-filter:hover {
    background: var(--c-black);
    color: var(--c-white);
  }
  .paper-list {
    list-style: none;
    padding: 0;
  }
  section h2 {
    border-bottom: 2px solid var(--c-black);
    padding-bottom: 0.2em;
  }
</style>
