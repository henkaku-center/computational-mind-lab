---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { t, formatDate, locales, type Locale } from '../../../i18n';
import { allTranslationKeys } from '../../../lib/translations';

export async function getStaticPaths() {
  const entries = await getCollection('news');
  const keys = allTranslationKeys(entries);
  return locales.flatMap((locale) => keys.map((slug) => ({ params: { locale, slug } })));
}

const { slug } = Astro.params;
const locale = Astro.params.locale as Locale;

const entries = (await getCollection('news')).filter((e) => e.data.translationKey === slug && !e.data.draft);
const exact = entries.find((e) => e.data.locale === locale);
const entry = exact ?? entries[0];
const isFallback = !exact;
const { Content } = await render(entry);
const contentLang = isFallback ? entry.data.locale : undefined;
---

<Base locale={locale} title={entry.data.title} description={entry.data.excerpt}>
  <article>
    <p class="date">{formatDate(entry.data.date, locale)}</p>
    <h1 lang={contentLang}>
      {entry.data.title}
      {isFallback && <span class="fallback">{t(locale, 'news.englishOnly')}</span>}
    </h1>
    {
      entry.data.translated === 'auto' && (
        <p class="notice" lang={locale}>
          {t(locale, 'news.autoTranslated')}
        </p>
      )
    }
    {
      entry.data.tags.length > 0 && (
        <p class="tags" lang={contentLang}>
          {entry.data.tags.join(' · ')}
        </p>
      )
    }
    <div lang={contentLang} class="body">
      <Content />
    </div>
  </article>
</Base>

<style>
  .date {
    font-size: var(--text-s);
    color: var(--c-dark-grey);
    margin-bottom: 0.4em;
  }
  .fallback {
    font-size: var(--text-s);
    font-weight: 400;
    color: var(--c-dark-grey);
  }
  .notice {
    border: 2px solid var(--c-gold);
    padding: 0.5em 0.8em;
    font-size: var(--text-s);
  }
  .tags {
    font-size: var(--text-s);
    color: var(--c-dark-grey);
  }
  .body {
    max-width: 46em;
  }
  h1 {
    font-size: calc(var(--text-l) * var(--lang-scale) * 1.3);
  }
</style>
