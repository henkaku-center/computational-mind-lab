---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { t, localeStaticPaths, type Locale } from '../../i18n';

export function getStaticPaths() {
  return localeStaticPaths();
}
const locale = Astro.params.locale as Locale;

const people = await getCollection('people');
type Person = (typeof people)[number];

const currentGroups = ['pi', 'members', 'undergrads', 'affiliates'] as const;
const alumniRoles = ['postdoc', 'grad', 'undergrad', 'staff'] as const;

const byWeight = (a: Person, b: Person) => a.data.weight - b.data.weight;
/** Alumni: most recently in the lab first; unknown years last. */
const byRecency = (a: Person, b: Person) =>
  (b.data.lastActiveYear ?? -Infinity) - (a.data.lastActiveYear ?? -Infinity) ||
  a.data.name.localeCompare(b.data.name);

function loc(entry: Person, field: 'name' | 'title' | 'blurb'): { text: string; lang?: string } {
  const ja = entry.data[`${field}Ja` as 'nameJa' | 'titleJa' | 'blurbJa'];
  if (locale === 'ja' && ja) return { text: ja };
  const en = entry.data[field] ?? '';
  return { text: en, lang: locale === 'ja' ? 'en' : undefined };
}

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

/** Renders a blurb as HTML, supporting only `[label](url)` inline links — everything else is escaped. */
function renderBlurb(text: string): string {
  return text
    .split(/(\[[^\]]+\]\([^)]+\))/g)
    .map((part) => {
      const m = part.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
      return m ? `<a href="${escapeHtml(m[2])}">${escapeHtml(m[1])}</a>` : escapeHtml(part);
    })
    .join('');
}

const sections = [
  ...currentGroups
    .map((group) => ({
      heading: t(locale, `people.${group}`),
      list: people.filter((p) => p.data.group === group).sort(byWeight),
      isAlumni: false,
    }))
    .filter((s) => s.list.length),
];

const alumniSections = alumniRoles
  .map((role) => ({
    heading: t(locale, `people.alumni.${role}`),
    list: people.filter((p) => p.data.group === 'alumni' && p.data.alumniRole === role).sort(byRecency),
  }))
  .filter((s) => s.list.length);
---

<Base locale={locale} title={t(locale, 'nav.people')}>
  <h1>{t(locale, 'nav.people')}</h1>

  {
    sections.map((section) => (
      <section>
        <h2>{section.heading}</h2>
        <div class="people-grid">
          {section.list.map((p) => {
            const name = loc(p, 'name');
            const title = loc(p, 'title');
            const blurb = loc(p, 'blurb');
            return (
              <article class="card">
                <img src={p.data.image} alt={p.data.name} loading="lazy" width="160" height="160" />
                <h3 lang={name.lang}>{p.data.website ? <a href={p.data.website}>{name.text}</a> : name.text}</h3>
                <p class="role" lang={title.lang}>
                  {title.text}
                </p>
                {blurb.text && (
                  <p lang={blurb.lang} class="blurb" set:html={renderBlurb(blurb.text)} />
                )}
                {p.data.email && (
                  <p class="role">
                    <a href={`mailto:${p.data.email}`}>{p.data.email}</a>
                  </p>
                )}
              </article>
            );
          })}
        </div>
      </section>
    ))
  }

  {
    alumniSections.length > 0 && (
      <section>
        <h2>{t(locale, 'people.alumni')}</h2>
        {alumniSections.map((section) => (
          <>
            <h3 class="alumni-role">{section.heading}</h3>
            <ul class="alumni-list">
              {section.list.map((p) => {
                const name = loc(p, 'name');
                return (
                  <li>
                    <span class="alumni-name" lang={name.lang}>
                      {p.data.website ? <a href={p.data.website}>{name.text}</a> : name.text}
                    </span>
                    {p.data.years && <span class="alumni-years"> · {p.data.years}</span>}
                    {p.data.currentPosition && (
                      <span class="alumni-now"> — {p.data.currentPosition}</span>
                    )}
                  </li>
                );
              })}
            </ul>
          </>
        ))}
      </section>
    )
  }
</Base>

<style>
  .people-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--grid);
    margin-block: var(--grid);
  }
  .card img {
    width: 160px;
    height: 160px;
    object-fit: cover;
    margin-bottom: 0.75em;
  }
  .card h3 {
    margin: 0 0 0.3em;
  }
  .role {
    font-size: var(--text-s);
    color: var(--c-dark-grey);
    margin: 0 0 0.3em;
  }
  .blurb {
    font-size: calc(var(--text-body) * var(--lang-scale) * 0.94);
  }
  section h2 {
    border-bottom: 2px solid var(--c-black);
    padding-bottom: 0.2em;
    margin-top: calc(var(--grid) * 1.5);
  }
  .alumni-role {
    margin-top: var(--grid);
    color: var(--c-dark-grey);
  }
  .alumni-list {
    list-style: none;
    padding: 0;
    margin-block: 0.5em var(--grid);
    columns: 2;
    column-gap: var(--grid);
  }
  @media (max-width: 720px) {
    .alumni-list {
      columns: 1;
    }
  }
  .alumni-list li {
    break-inside: avoid;
    margin-bottom: 0.4em;
  }
  .alumni-name {
    font-weight: 700;
  }
  .alumni-years,
  .alumni-now {
    font-size: var(--text-s);
    color: var(--c-dark-grey);
  }
</style>
