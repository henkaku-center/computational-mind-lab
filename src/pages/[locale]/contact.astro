---
import Base from '../../layouts/Base.astro';
import { t, localeStaticPaths, type Locale } from '../../i18n';

export function getStaticPaths() {
  return localeStaticPaths();
}
const locale = Astro.params.locale as Locale;

// TODO-review: add Joe's Chiba Tech email once confirmed (see TRANSITION.md).
const copy = {
  en: {
    pi: 'Joseph Austerweil — Professor & Academic Director, School of Design & Science',
    addressLabel: 'Address',
    address: ['School of Design & Science', 'Chiba Institute of Technology', '2-17-1 Tsudanuma, Narashino', 'Chiba 275-0016, Japan'],
  },
  ja: {
    pi: 'Joseph Austerweil（ジョセフ・オースターワイル）— 教授・デザイン＆サイエンス学部アカデミックディレクター',
    addressLabel: '所在地',
    address: ['〒275-0016', '千葉県習志野市津田沼2-17-1', '千葉工業大学', 'デザイン＆サイエンス学部'],
  },
}[locale];
---

<Base locale={locale} title={t(locale, 'contact.title')}>
  <h1>{t(locale, 'contact.title')}</h1>
  <p>{copy.pi}</p>
  <h2>{copy.addressLabel}</h2>
  <p>{copy.address.map((line) => <>{line}<br /></>)}</p>
  <p><a href="https://github.com/AusterweilLab">github.com/AusterweilLab</a></p>
</Base>
